{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "NotebookEdit",
      "Bash",
      "WebFetch",
      "WebSearch",
      "Glob",
      "Grep",
      "Task",
      "TodoWrite",
      "ExitPlanMode",
      "Skill",
      "BashOutput",
      "KillShell"
    ],
    "deny": [],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git merge:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git clean:*)",
      "Bash(git stash drop:*)",
      "Bash(git stash pop:*)",
      "Bash(docker *)",
      "Bash(gh:*)",
      "Bash(npm publish:*)",
      "Bash(npm version:*)",
      "Bash(rm:*)",
      "Bash(rm -r:*)",
      "Bash(rm -rf:*)",
      "Bash(npm install:*)",
      "Bash(npm i:*)",
      "Bash(npm exec:*)",
      "Bash(npx:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm dlx:*)",
      "Bash(yarn add:*)",
      "Bash(pip install:*)",
      "Bash(pip3 install:*)",
      "Bash(python -m pip install:*)",
      "Bash(pipx:*)",
      "Bash(uv add:*)",
      "Bash(uv pip install:*)",
      "Bash(uv tool:*)",
      "Bash(uvx:*)",
      "Bash(winget install:*)",
      "Bash(choco:*)",
      "Bash(scoop:*)",
      "Bash(cargo install:*)",
      "Bash(go install:*)",
      "Bash(dotnet tool:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(iwr:*)",
      "Bash(irm:*)",
      "Bash(iex:*)",
      "PowerShell(npm install:*)",
      "PowerShell(npx:*)",
      "PowerShell(pip install:*)",
      "PowerShell(pipx:*)",
      "PowerShell(uvx:*)",
      "PowerShell(winget install:*)",
      "PowerShell(choco:*)",
      "PowerShell(scoop:*)",
      "PowerShell(iwr:*)",
      "PowerShell(irm:*)",
      "PowerShell(iex:*)",
      "PowerShell(Invoke-WebRequest:*)",
      "PowerShell(Invoke-RestMethod:*)",
      "PowerShell(Invoke-Expression:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"<TU_CARPETA_HOME>\\.claude\\scripts\\hook-session-start.ps1\"",
            "timeout": 10,
            "statusMessage": "Reinyectando reglas de aislamiento (SABIO)..."
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "cat ~/.claude/scripts/continuity-flush.json",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": []
  },
  "env": {},
  "outputStyle": "default",
  "theme": "auto",
  "thinkingMode": "enabled"
}
